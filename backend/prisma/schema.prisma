generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Product {
  id          Int       @id @default(autoincrement())
  name        String
  price       Float

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  categoryId  Int?
  category    Category? @relation(fields: [categoryId], references: [id])

  sales       Sale[]
}

model Category {
  id        Int       @id @default(autoincrement())
  name      String    @unique

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  products  Product[]
}

model Table {
  id        Int      @id @default(autoincrement())
  number    String
  status    String   @default("open")
  total     Float    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sales     Sale[]
  payments  Payment[]
}

model Sale {
  id        Int      @id @default(autoincrement())
  amount    Float
  method    String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  productId Int?
  product   Product? @relation(fields: [productId], references: [id])

  tableId   Int?
  table     Table?   @relation(fields: [tableId], references: [id])
}

model Payment {
  id        Int      @id @default(autoincrement())
  amount    Float
  method    String
  tableId   Int

  createdAt DateTime @default(now())

  table     Table    @relation(fields: [tableId], references: [id])
}