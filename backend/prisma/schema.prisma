generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Product {
  id        Int      @id @default(autoincrement())
  name      String
  price     Float
  createdAt DateTime @default(now())

  sales     Sale[]
}

model Sale {
  id        Int      @id @default(autoincrement())
  amount    Float
  method    String
  createdAt DateTime @default(now())

  productId Int?
  product   Product? @relation(fields: [productId], references: [id])
}